<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.ItemsListPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="{Binding Title}">

    <VerticalStackLayout Padding="20" Spacing="15">
        <Label Text="Available Items"
               FontSize="24"
               FontAttributes="Bold" />

        <CollectionView ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="#DDDDDD"
                            StrokeThickness="1"
                            Padding="12"
                            Margin="0,5">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="8" />
                        </Border.StrokeShape>
                        <Label Text="{Binding .}"
                               FontSize="18" />
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </VerticalStackLayout>
</ContentPage>